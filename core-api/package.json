{
  "name": "core-api-docker",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"data/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "prestart:prod": "node aws-secret-manager",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,data,apps,libs,test}/**/*.ts\" --fix",
    "test": "cross-env NODE_ENV=automated_tests jest",
    "test:watch": "cross-env NODE_ENV=automated_tests jest --watch",
    "test:cov": "cross-env NODE_ENV=automated_tests jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli -d ./src/configuration/orm.configuration.ts",
    "schema:drop": "cross-env NODE_ENV=development npm run typeorm -- schema:drop",
    "schema:sync": "cross-env NODE_ENV=development npm run typeorm -- schema:sync",
    "migration:create": "cross-var ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli migration:create ./data/migrations/$npm_config_name",
    "migration:generate": "cross-var npm run typeorm migration:generate ./data/migrations/$npm_config_name",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "test:verify-investor": "ts-node -r tsconfig-paths/register ./scripts/test-verify-investor.ts",
    "custody:backfill-approved-investors": "ts-node -r tsconfig-paths/register ./scripts/custody-backfill-approved-investors.ts",
    "fixtures": "cross-env NODE_ENV=development fixtures load ./data/fixture --sync --debug --dataSource=./src/configuration/orm.configuration.ts --require=ts-node/register --require=tsconfig-paths/register",
    "sonar": " ts-node src/configuration/sonar-project.ts",
    "prepare": "husky install",
    "hola": "echo $npm_config_hola"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "data/**/*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1028.0",
    "@aws-sdk/s3-request-presigner": "^3.1028.0",
    "@casl/ability": "^6.8.0",
    "@nestjs/common": "^11.1.14",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.14",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.14",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/typeorm": "^11.0.0",
    "@stellar/stellar-sdk": "^14.5.0",
    "amazon-cognito-identity-js": "^6.3.16",
    "auth0": "^4.37.0",
    "axios": "^1.15.2",
    "better-sqlite3": "^12.6.2",
    "change-case-all": "^2.1.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "crypto": "^1.0.1",
    "crypto-js": "^4.2.0",
    "joi": "^18.0.2",
    "jsonapi-serializer": "^3.6.9",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^3.2.2",
    "otpauth": "^9.5.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.18.0",
    "recharts": "^3.8.0",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.1.3",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.28",
    "typeorm-naming-strategies": "^4.1.0",
    "typeorm-transactional": "^0.5.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.14",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonapi-serializer": "^3.6.8",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.3.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "cross-env": "^10.1.0",
    "cross-var": "^1.1.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-sonar-reporter": "^2.0.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "sonarqube-scanner": "^4.3.4",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typeorm-fixtures-cli": "^4.1.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "moduleNameMapper": {
      "@modules/(.*)$": "<rootDir>/modules/$1",
      "@common/(.*)$": "<rootDir>/common/$1",
      "^@root/(.*)$": "<rootDir>/../$1",
      "^@data/(.*)$": "<rootDir>/../data/$1",
      "^@/(.*)$": "<rootDir>/../src/$1",
      "@configuration/(.*)$": "<rootDir>/configuration/$1"
    },
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coveragePathIgnorePatterns": [
      "^.*.dto.ts$"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "testResultsProcessor": "jest-sonar-reporter"
  },
  "jestSonar": {
    "reportPath": "coverage",
    "reportFile": "test-reporter.xml",
    "indent": 4
  }
}
