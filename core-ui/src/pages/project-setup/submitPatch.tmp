const handleSubmitProject = async () => {
  if (!canSubmitProject) return;

  try {
    let projectId = draftId;

    if (!projectId) {
      const created = await projectService.createProject(form);
      projectId = created.data?.id;
    } else {
      await projectService.saveDraft(projectId, form);
    }

    await projectService.submitProject(projectId);

    setSaveMessage('Project submitted for review');

    setTimeout(() => {
      navigate('/projects');
    }, 1000);
  } catch (error) {
    console.error('Submit failed', error);
    setSaveMessage('Submission failed');
  }
};
