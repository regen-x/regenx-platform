import { useEffect, useState } from 'react';
import { useNavigate } from 'react-router-dom';

import {
	AdminActionButton,
	AdminPageHeader,
	AdminSectionCard,
	AdminStatCard,
	AdminStatusBadge,
} from '@/components/admin-ui';
import { IProject } from '@/interfaces/api/IProject';
import { projectService } from '@/services/project.service';

type ProjectStatus =
	| 'draft'
	| 'under_review'
	| 'changes_requested'
	| 'approved'
	| 'issued'
	| 'live'
	| 'locked';

type Project = {
	id: string;
	projectName: string;
	projectType: string;
	fundingGoal: string;
	location: string;
	status: ProjectStatus;
	submittedAt: string;
};

const formatCurrency = (value?: string) => {
	const raw = String(value ?? '')
		.replace(/,/g, '')
		.trim();
	const num = Number(raw);
	if (!raw || Number.isNaN(num)) return '—';
	return `$${num.toLocaleString()}`;
};

export default function AdminDashboard() {
	const navigate = useNavigate();
	const [projects, setProjects] = useState<Project[]>([]);

	useEffect(() => {
		const load = async () => {
			try {
				const res = await projectService.getAdminProjects();

				const mapped = (res ?? []).map((p: IProject) => ({
					id: p.id ?? '',
					projectName: p.name ?? 'Untitled Project',
					projectType: p.projectType ?? '',
					fundingGoal: String(p.fundingGoal ?? '0'),
					location: p.location ?? '',
					status: (p.status as ProjectStatus) ?? 'draft',
					submittedAt: p.submittedAt ?? p.createdAt ?? '',
				}));

				setProjects(mapped);
			} catch (error) {
				console.error('Failed to load admin projects', error);
				setProjects([]);
			}
		};

		void load();
	}, []);

	const pending = projects.filter((p) => p.status === 'under_review');
	const changes = projects.filter((p) => p.status === 'changes_requested');
	const approved = projects.filter((p) =>
		['approved', 'issued', 'live'].includes(p.status),
	);
	const incompleteDocs = projects.filter(
		(p) => !['approved', 'issued', 'live'].includes(p.status),
	);

	const reviewQueue = [...projects]
		.filter((p) => !['approved', 'issued', 'live'].includes(p.status))
		.sort(
			(a, b) =>
				new Date(b.submittedAt || 0).getTime() -
				new Date(a.submittedAt || 0).getTime(),
		)
		.slice(0, 5);

	const capitalUnderReview = projects
		.filter((p) => !['approved', 'issued', 'live'].includes(p.status))
		.reduce(
			(sum, p) =>
				sum + Number(String(p.fundingGoal ?? '0').replace(/,/g, '') || 0),
			0,
		);

	const badgeTone = (
		status: ProjectStatus,
	): 'yellow' | 'pink' | 'blue' | 'gray' => {
		if (status === 'under_review') return 'yellow';
		if (status === 'changes_requested') return 'pink';
		if (['approved', 'issued', 'live'].includes(status)) return 'blue';
		return 'gray';
	};

	return (
		<div className="min-h-screen bg-[#F8FAFC]">
			<div className="px-6 pb-8 pt-6 md:px-8 xl:px-10">
				<AdminPageHeader
					title="Administrator Dashboard"
					description="Manage project approvals, investors, and platform activity"
				/>

				<div className="grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-4">
					<AdminStatCard
						label="Projects Pending Review"
						value={pending.length}
						helper="Awaiting approval"
						tone="pink"
					/>
					<AdminStatCard
						label="Changes Requested"
						value={changes.length}
						helper="Sent back to developers"
						tone="yellow"
					/>
					<AdminStatCard
						label="Approved Projects"
						value={approved.length}
						helper="Approved, issued, or live"
						tone="blue"
					/>
					<AdminStatCard
						label="Incomplete Docs"
						value={incompleteDocs.length}
						helper="Requires attention"
						tone="neutral"
					/>
				</div>

				<div className="mt-6 flex flex-col items-start justify-between gap-4 rounded-[24px] border border-[#F3D98B] bg-[#FFF6D8] px-6 py-5 md:flex-row md:items-center">
					<div>
						<p className="font-semibold text-[#101828]">
							Review required across active submissions
						</p>
						<p className="text-sm text-[#946200]">
							Ensure legal, agreements, and documentation are complete
						</p>
					</div>

					<AdminActionButton
						tone="primary"
						onClick={() => navigate('/admin/project-approvals')}
					>
						Review Now
					</AdminActionButton>
				</div>

				<div className="mt-6 grid grid-cols-1 gap-6 xl:grid-cols-12">
					<div className="xl:col-span-8">
						<AdminSectionCard title="Pending Project Approvals">
							<div className="overflow-x-auto">
								<table className="w-full text-sm">
									<thead className="text-left text-[#98A2B3]">
										<tr>
											<th className="pb-4 pr-6 font-medium">Project</th>
											<th className="pb-4 pr-6 font-medium">Type</th>
											<th className="pb-4 pr-6 font-medium">Submitted</th>
											<th className="pb-4 pr-6 font-medium">Target</th>
											<th className="pb-4 pr-6 font-medium">Status</th>
											<th className="pb-4 font-medium text-right">Action</th>
										</tr>
									</thead>

									<tbody>
										{reviewQueue.map((p) => (
											<tr
												key={p.id}
												className="border-t border-[#E6ECF5] align-top"
											>
												<td className="py-5 pr-6 text-[#101828]">
													<div className="max-w-[360px] text-[17px] font-semibold leading-[1.35]">
														{p.projectName}
													</div>
													<div className="mt-2 text-sm leading-[1.45] text-[#98A2B3]">
														{p.location || '—'}
													</div>
												</td>

												<td className="py-5 pr-6 text-[16px] text-[#101828]">
													{p.projectType || '—'}
												</td>

												<td className="py-5 pr-6 text-[16px] text-[#101828]">
													{p.submittedAt
														? new Date(p.submittedAt).toLocaleDateString()
														: '—'}
												</td>

												<td className="py-5 pr-6 text-[16px] font-medium text-[#101828]">
													{formatCurrency(p.fundingGoal)}
												</td>

												<td className="py-5 pr-6">
													<AdminStatusBadge
														label={p.status.replaceAll('_', ' ')}
														tone={badgeTone(p.status)}
													/>
												</td>

												<td className="py-5 text-right">
													<AdminActionButton
														onClick={() =>
															navigate(`/admin/project-approvals/${p.id}`)
														}
													>
														Review
													</AdminActionButton>
												</td>
											</tr>
										))}

										{!reviewQueue.length ? (
											<tr>
												<td
													colSpan={6}
													className="py-8 text-center text-sm text-[#98A2B3]"
												>
													No projects currently in the review queue
												</td>
											</tr>
										) : null}
									</tbody>
								</table>
							</div>
						</AdminSectionCard>
					</div>

					<div className="space-y-6 xl:col-span-4">
						<AdminSectionCard title="Capital Under Review">
							<div className="text-[28px] font-semibold text-[#101828]">
								{formatCurrency(String(capitalUnderReview))}
							</div>
							<div className="mt-2 text-sm text-[#667085]">
								Estimated capital across active submissions
							</div>
						</AdminSectionCard>

						<AdminSectionCard title="Review Breakdown">
							<div className="space-y-3 text-sm text-[#101828]">
								<div>Under Review: {pending.length}</div>
								<div>Changes Requested: {changes.length}</div>
								<div>Approved / Issued / Live: {approved.length}</div>
							</div>
						</AdminSectionCard>

						<AdminSectionCard title="Health Status">
							<p className="text-sm text-[#667085]">
								Pipeline efficiency is stable across submissions.
							</p>
						</AdminSectionCard>
					</div>
				</div>
			</div>
		</div>
	);
}
